{
  "expo": {
    "name": "Expo Sample App",
    "slug": "expo-sample-app",
    "scheme": "expo-sample-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "sdkVersion": "53.0.0",
    "jsEngine": "hermes",
    "plugins": [
      "expo-router"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.example.exposampleapp"
    },
    "ios": {
      "bundleIdentifier": "com.example.exposampleapp"
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
